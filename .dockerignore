# Generated by /carthage-annex. The build context is the project root,
# so excluding large directories here keeps image builds snappy.

# VCS
.git/
.gitignore

# Python
.venv/
venv/
__pycache__/
*.pyc
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Node
node_modules/
npm-debug.log
yarn-error.log

# Rust / Go / Java build outputs
target/
dist/
build/
*.class

# Editor / OS
.vscode/
.idea/
.DS_Store

# Carthage's own hash cache
.carthage/last-build-hash
